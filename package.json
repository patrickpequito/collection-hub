{
  "name": "d2-collector",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "generate:armor-sets": "node scripts/generate-armor-sets.mjs",
    "generate:exotics": "node scripts/generate-exotics.mjs",
    "generate:catalysts": "node scripts/generate-catalysts.mjs",
    "generate:triumphs": "node scripts/generate-triumphs.mjs",
    "generate:item-index": "node scripts/generate-item-hash-index.mjs",
    "setup:https": "mkdir -p certificates && test -f certificates/localhost.pem || openssl req -x509 -newkey rsa:2048 -keyout certificates/localhost-key.pem -out certificates/localhost.pem -days 365 -nodes -subj '/CN=127.0.0.1'",
    "dev": "npm run setup:https && next dev --experimental-https --experimental-https-key ./certificates/localhost-key.pem --experimental-https-cert ./certificates/localhost.pem -H 127.0.0.1 -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
